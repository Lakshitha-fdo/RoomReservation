@startuml
actor Staff
participant "BillDialog" as BD
participant "BillingController" as BC
participant "ApiClient" as AC
participant "ApiServer" as AS
participant "BillingService" as BS
participant "ReservationService" as RS
participant "JdbcReservationDao" as DAO
database "SQLite DB" as DB

Staff -> BD : Enter reservation number
BD -> BC : generateBill(id)
BC -> AC : GET /api/bill/{id}
AC -> AS : HTTP request
AS -> BS : generateBill(id)
BS -> RS : findById(id)
RS -> DAO : findById(id)
DAO -> DB : SELECT reservation
DB --> DAO : reservation row
DAO --> RS : Reservation
RS --> BS : Reservation
BS --> AS : Bill(nights, rate, total)
AS --> AC : 200 + bill JSON
AC --> BC : Bill result
BC --> BD : Display total
@enduml
