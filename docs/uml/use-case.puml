@startuml
left to right direction
skinparam packageStyle rectangle

actor Staff
actor System

rectangle "Ocean View Reservation System" {
  usecase "Login" as UC1
  usecase "Add Reservation" as UC2
  usecase "View Reservation" as UC3
  usecase "Calculate Bill" as UC4
  usecase "Help" as UC5
  usecase "Exit" as UC6
}

Staff --> UC1
Staff --> UC2
Staff --> UC3
Staff --> UC4
Staff --> UC5
Staff --> UC6

System --> UC1
System --> UC2
System --> UC3
System --> UC4
System --> UC5
System --> UC6

UC2 ..> UC1 : <<include>>
UC3 ..> UC1 : <<include>>
UC4 ..> UC1 : <<include>>
@enduml
